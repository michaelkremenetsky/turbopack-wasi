From: michaelkremenetsky
 <28833521+michaelkremenetsky@users.noreply.github.com>
Date: Thu, 16 Jul 2026 06:22:25 -0700
Subject: [PATCH 10/11] wasi runtime fixes: temp_dir, tokio runtime init,
 thread parker, parallelism

- PANIC_LOG used std::env::temp_dir(), which panics on wasi; fall back to
  TMPDIR or /tmp
- add initTurbopackWasiRuntime(threads): napi's wasm fallback is a
  current-thread tokio runtime that only advances while a napi call blocks
  on it, stalling turbo-tasks background work; wasm hosts call this once
  after instantiation to install a real multi-threaded runtime
- parking_lot_core 0.9.8 selects a panicking stub thread parker on wasi;
  0.9.12 + the nightly feature provides the wasm atomics parker
- turbo-tasks scopes fell back to zero workers on wasi because
  available_parallelism is unsupported there; honor TURBOPACK_PARALLELISM
  or default to a small pool
---
 Cargo.lock                                    | 20 +++++++++----
 crates/next-napi-bindings/Cargo.toml          |  4 +++
 crates/next-napi-bindings/src/lib.rs          | 28 +++++++++++++++++++
 .../src/next_api/turbopack_ctx.rs             |  4 +++
 turbopack/crates/turbo-tasks/src/scope.rs     | 12 +++++++-
 .../crates/turbopack-trace-utils/src/exit.rs  |  6 +++-
 6 files changed, 67 insertions(+), 7 deletions(-)

diff --git a/crates/next-napi-bindings/Cargo.toml b/crates/next-napi-bindings/Cargo.toml
index ae0fe061..e25a7d33 100644
--- a/crates/next-napi-bindings/Cargo.toml
+++ b/crates/next-napi-bindings/Cargo.toml
@@ -143,6 +143,10 @@ mdxjs = { workspace = true, features = ["serializable"] }
 
 turbo-tasks-malloc = { workspace = true, default-features = false }
 
+# parking_lot's wasm atomics thread parker (rather than a panicking stub) is nightly-gated;
+# needs >=0.9.12 for wasi support.
+parking_lot_core = { version = "0.9.12", features = ["nightly"] }
+
 turbo-rcstr = { workspace = true, features = ["napi"] }
 turbo-tasks = { workspace = true }
 turbo-tasks-backend = { workspace = true }
diff --git a/crates/next-napi-bindings/src/lib.rs b/crates/next-napi-bindings/src/lib.rs
index a9e5fc01..81cb06f2 100644
--- a/crates/next-napi-bindings/src/lib.rs
+++ b/crates/next-napi-bindings/src/lib.rs
@@ -66,6 +66,34 @@ static ALLOC: turbo_tasks_malloc::TurboMalloc = turbo_tasks_malloc::TurboMalloc;
 #[global_allocator]
 static ALLOC: dhat::Alloc = dhat::Alloc;
 
+/// On wasm, napi's fallback is a current-thread tokio runtime that only advances while a napi
+/// call is blocked on it, which stalls turbo-tasks' background work. Wasm hosts must call this
+/// once, right after instantiation and before any turbopack call, to install a proper
+/// multi-threaded runtime (worker threads are spawned as wasi threads).
+#[cfg(target_arch = "wasm32")]
+#[napi_derive::napi]
+pub fn init_turbopack_wasi_runtime(worker_threads: Option<u32>) -> napi::Result<()> {
+    use tokio::runtime::Builder;
+    use turbo_tasks_malloc::TurboMalloc;
+
+    let threads = worker_threads.unwrap_or(4).max(1) as usize;
+    let rt = Builder::new_multi_thread()
+        .worker_threads(threads)
+        // std::thread::available_parallelism is unsupported on wasi; every implicit sizing
+        // must be explicit here.
+        .max_blocking_threads(threads * 4)
+        .enable_all()
+        .on_thread_stop(|| {
+            TurboMalloc::thread_stop();
+        })
+        .build()
+        .map_err(|err| {
+            napi::Error::from_reason(format!("failed to build tokio runtime: {err}"))
+        })?;
+    napi::bindgen_prelude::create_custom_tokio_runtime(rt);
+    Ok(())
+}
+
 #[cfg(not(target_arch = "wasm32"))]
 #[napi::module_init]
 fn init() {
diff --git a/crates/next-napi-bindings/src/next_api/turbopack_ctx.rs b/crates/next-napi-bindings/src/next_api/turbopack_ctx.rs
index f231e857..df15d6b6 100644
--- a/crates/next-napi-bindings/src/next_api/turbopack_ctx.rs
+++ b/crates/next-napi-bindings/src/next_api/turbopack_ctx.rs
@@ -295,6 +295,10 @@ impl CompilationEvent for StartupCacheInvalidationEvent {
 static LOG_THROTTLE: Mutex<Option<Instant>> = Mutex::new(None);
 static LOG_DIVIDER: &str = "---------------------------";
 static PANIC_LOG: Lazy<PathBuf> = Lazy::new(|| {
+    // std::env::temp_dir() panics on wasi; fall back to TMPDIR (which the host controls) or /tmp.
+    #[cfg(target_family = "wasm")]
+    let mut path = PathBuf::from(env::var("TMPDIR").unwrap_or_else(|_| "/tmp".to_string()));
+    #[cfg(not(target_family = "wasm"))]
     let mut path = env::temp_dir();
     path.push(format!("next-panic-{:x}.log", rand::random::<u128>()));
     path
diff --git a/turbopack/crates/turbo-tasks/src/scope.rs b/turbopack/crates/turbo-tasks/src/scope.rs
index 9ff99a36..2ebf8f10 100644
--- a/turbopack/crates/turbo-tasks/src/scope.rs
+++ b/turbopack/crates/turbo-tasks/src/scope.rs
@@ -22,7 +22,17 @@ use crate::{TurboTasksApi, manager::try_turbo_tasks, turbo_tasks_scope};
 
 /// Number of worker tasks to spawn that process jobs. It's 1 less than the number of cpus as we
 /// also use the current task as worker.
-static WORKER_TASKS: Lazy<usize> = Lazy::new(|| available_parallelism().map_or(0, |n| n.get() - 1));
+static WORKER_TASKS: Lazy<usize> = Lazy::new(|| {
+    available_parallelism().map(|n| n.get() - 1).unwrap_or_else(|_| {
+        // std cannot detect parallelism on wasi; let the host specify it via env, defaulting to
+        // a small pool instead of falling back to fully sequential scopes.
+        std::env::var("TURBOPACK_PARALLELISM")
+            .ok()
+            .and_then(|s| s.parse::<usize>().ok())
+            .unwrap_or(4)
+            .saturating_sub(1)
+    })
+});
 
 enum WorkQueueJob {
     Job(usize, Box<dyn FnOnce() + Send + 'static>),
diff --git a/turbopack/crates/turbopack-trace-utils/src/exit.rs b/turbopack/crates/turbopack-trace-utils/src/exit.rs
index e53f3d84..aadae909 100644
--- a/turbopack/crates/turbopack-trace-utils/src/exit.rs
+++ b/turbopack/crates/turbopack-trace-utils/src/exit.rs
@@ -1,7 +1,11 @@
