From 30e118479f9575283001d24edd3c436d2695bfe2 Mon Sep 17 00:00:00 2001
From: michaelkremenetsky
 <28833521+michaelkremenetsky@users.noreply.github.com>
Date: Thu, 16 Jul 2026 03:31:29 -0700
Subject: [PATCH 5/8] turbo-tasks-fs: support symlink creation on wasi

Use std::os::wasi::fs::symlink_path (nightly wasi_ext) where the unix
symlink API was assumed. The notify-based watcher already builds on wasi
via notify's PollWatcher fallback.
---
 turbopack/crates/turbo-tasks-fs/src/lib.rs | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/turbopack/crates/turbo-tasks-fs/src/lib.rs b/turbopack/crates/turbo-tasks-fs/src/lib.rs
index da76f3e6..4c50bd21 100644
--- a/turbopack/crates/turbo-tasks-fs/src/lib.rs
+++ b/turbopack/crates/turbo-tasks-fs/src/lib.rs
@@ -1,6 +1,8 @@
 #![feature(arbitrary_self_types)]
 #![feature(arbitrary_self_types_pointers)]
 #![feature(btree_cursors)] // needed for the `InvalidatorMap` and watcher, reduces time complexity
+// needed for `std::os::wasi::fs::symlink_path` on wasm32-wasi targets
+#![cfg_attr(target_os = "wasi", feature(wasi_ext))]
 #![feature(io_error_more)]
 #![feature(iter_advance_by)]
 #![feature(min_specialization)]
@@ -1229,8 +1231,10 @@ impl FileSystem for DiskFileSystem {
                             })?;
                             has_old_content = false;
                         }
-                        #[cfg(not(windows))]
+                        #[cfg(not(any(windows, target_os = "wasi")))]
                         let io_result = std::os::unix::fs::symlink(&target, &full_path);
+                        #[cfg(target_os = "wasi")]
+                        let io_result = std::os::wasi::fs::symlink_path(&target, &full_path);
                         #[cfg(windows)]
                         let io_result = if is_directory {
                             std::os::windows::fs::junction_point(&target, &full_path)
-- 
