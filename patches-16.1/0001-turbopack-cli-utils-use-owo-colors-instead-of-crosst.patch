From a2efa8390788f23f9114cd5928434f8e1cd8a1cc Mon Sep 17 00:00:00 2001
From: michaelkremenetsky
 <28833521+michaelkremenetsky@users.noreply.github.com>
Date: Thu, 16 Jul 2026 03:25:02 -0700
Subject: [PATCH 01/12] turbopack-cli-utils: use owo-colors instead of
 crossterm for issue styling

crossterm does not build on wasm32-wasip1-threads (terminal/event machinery);
its only use here was ANSI string styling, which owo-colors (already a
dependency of this crate) covers on every platform.
---
 turbopack/crates/turbopack-cli-utils/Cargo.toml   |  1 -
 turbopack/crates/turbopack-cli-utils/src/issue.rs | 11 ++++-------
 2 files changed, 4 insertions(+), 8 deletions(-)

diff --git a/turbopack/crates/turbopack-cli-utils/Cargo.toml b/turbopack/crates/turbopack-cli-utils/Cargo.toml
index 2cae9739..34c5d106 100644
--- a/turbopack/crates/turbopack-cli-utils/Cargo.toml
+++ b/turbopack/crates/turbopack-cli-utils/Cargo.toml
@@ -16,7 +16,6 @@ workspace = true
 
 [dependencies]
 anyhow = { workspace = true }
-crossterm = "0.26.0"
 owo-colors = { workspace = true }
 rustc-hash = { workspace = true }
 serde = { workspace = true, features = ["derive"] }
diff --git a/turbopack/crates/turbopack-cli-utils/src/issue.rs b/turbopack/crates/turbopack-cli-utils/src/issue.rs
index 52bcda13..b3b68bc5 100644
--- a/turbopack/crates/turbopack-cli-utils/src/issue.rs
+++ b/turbopack/crates/turbopack-cli-utils/src/issue.rs
@@ -8,7 +8,6 @@ use std::{
 };
 
 use anyhow::Result;
-use crossterm::style::{StyledContent, Stylize};
 use owo_colors::{OwoColorize as _, Style};
 use rustc_hash::{FxHashMap, FxHashSet};
 use turbo_rcstr::RcStr;
@@ -537,15 +536,11 @@ fn make_relative_to_cwd<'a>(path: &'a str, project_dir: &Path, cwd: &Path) -> Co
     }
 }
 
-fn show_all_message(label: &str, size: usize) -> StyledContent<String> {
+fn show_all_message(label: &str, size: usize) -> String {
     show_all_message_with_shown_count(label, size, DEFAULT_SHOW_COUNT)
 }
 
-fn show_all_message_with_shown_count(
-    label: &str,
-    size: usize,
-    shown: usize,
-) -> StyledContent<String> {
+fn show_all_message_with_shown_count(label: &str, size: usize, shown: usize) -> String {
     if shown == 0 {
         format!(
             "... [{} {label}] are hidden, run with {} to show them",
@@ -553,6 +548,7 @@ fn show_all_message_with_shown_count(
             "--show-all".bright_green()
         )
         .bold()
+        .to_string()
     } else {
         format!(
             "... [{} more {label}] are hidden, run with {} to show all",
@@ -560,6 +556,7 @@ fn show_all_message_with_shown_count(
             "--show-all".bright_green()
         )
         .bold()
+        .to_string()
     }
 }
 
